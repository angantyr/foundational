<div style="max-width: 1200px; margin: 0 auto; padding: var(--size-12);">
  <!-- Desktop: Carousel with feature cards -->
  <div class="carousel-container">
    <%= render Design::Navigation::Carousel::WidgetComponent.new(pagination_position: :top) do |widget| %>
      <!-- Feature Cards as Pagination -->
      <% features.each_with_index do |feature, index| %>
        <% widget.with_pagination do %>
          <button type="button"
                  class="feature-card"
                  data-carousel-target="pagination"
                  data-action="carousel#goToSlide"
                  data-index="<%= index %>"
                  aria-label="View <%= feature.header %>">
            <div class="feature-card__icon">
              <%= inline_svg_tag "icons/#{feature.icon}.svg", class: "icon" %>
            </div>
            <h3 class="feature-card__header"><%= feature.header %></h3>
            <p class="feature-card__summary"><%= feature.summary %></p>
          </button>
        <% end %>
      <% end %>

      <!-- Slides -->
      <% features.each do |feature| %>
        <% widget.with_slide do %>
          <%= image_tag feature.preview.src, alt: feature.preview.caption, class: "w-full rounded-md" %>
        <% end %>
      <% end %>

      <!-- Navigation -->
      <% widget.with_navigation do %>
        <button type="button"
                data-action="carousel#prev"
                class="carousel__nav carousel__nav--prev"
                aria-label="Previous slide">
          ‹
        </button>
        <button type="button"
                data-action="carousel#next"
                class="carousel__nav carousel__nav--next"
                aria-label="Next slide">
          ›
        </button>
      <% end %>
    <% end %>
  </div>

  <!-- Mobile: Stacked cards -->
  <div class="mobile-stack">
    <% features.each do |feature| %>
      <div class="mobile-feature">
        <div class="mobile-feature__card">
          <div class="mobile-feature__icon">
            <%= inline_svg_tag "icons/#{feature.icon}.svg", class: "icon" %>
          </div>
          <h3 class="mobile-feature__header"><%= feature.header %></h3>
          <p class="mobile-feature__summary"><%= feature.summary %></p>
        </div>
        <div class="mobile-feature__image-container">
          <%= image_tag feature.preview.src, alt: feature.preview.caption, class: "rounded-md" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
