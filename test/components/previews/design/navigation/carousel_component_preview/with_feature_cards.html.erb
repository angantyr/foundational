<div style="max-width: 1200px; margin: 0 auto; padding: var(--size-12);">
  <!-- Desktop: Carousel with feature cards -->
  <div class="carousel-container">
    <%= render Design::Navigation::Carousel::WidgetComponent.new(pagination_position: :top) do |widget| %>
      <!-- Feature Cards as Pagination -->
      <% features.each_with_index do |feature, index| %>
        <% widget.with_pagination do %>
          <button type="button"
                  class="feature-card"
                  data-carousel-target="pagination"
                  data-action="carousel#goToSlide"
                  data-index="<%= index %>"
                  aria-label="View <%= feature.header %>">
            <div class="feature-card__icon">
              <%= inline_svg_tag "icons/#{feature.icon}.svg", class: "icon" %>
            </div>
            <h3 class="feature-card__header"><%= feature.header %></h3>
            <p class="feature-card__summary"><%= feature.summary %></p>
          </button>
        <% end %>
      <% end %>

      <!-- Slides -->
      <% features.each do |feature| %>
        <% widget.with_slide do %>
          <%= image_tag feature.preview.src, alt: feature.preview.caption, class: "w-full rounded-md" %>
        <% end %>
      <% end %>

      <!-- Navigation -->
      <% widget.with_navigation do %>
        <button type="button"
                data-action="carousel#prev"
                class="carousel__nav carousel__nav--prev"
                aria-label="Previous slide">
          ‹
        </button>
        <button type="button"
                data-action="carousel#next"
                class="carousel__nav carousel__nav--next"
                aria-label="Next slide">
          ›
        </button>
      <% end %>
    <% end %>
  </div>

  <!-- Mobile: Stacked cards -->
  <div class="mobile-stack">
    <% features.each do |feature| %>
      <div class="mobile-feature">
        <div class="mobile-feature__card">
          <div class="mobile-feature__icon">
            <%= inline_svg_tag "icons/#{feature.icon}.svg", class: "icon" %>
          </div>
          <h3 class="mobile-feature__header"><%= feature.header %></h3>
          <p class="mobile-feature__summary"><%= feature.summary %></p>
        </div>
        <div class="mobile-feature__image-container">
          <%= image_tag feature.preview.src, alt: feature.preview.caption, class: "rounded-md" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  /* Feature Cards Grid */
  .carousel__pagination {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--size-6);
    margin-block-end: 0;
  }

  .feature-card {
    padding: var(--size-6);
    background: transparent;
    border: none;
    border-radius: var(--rounded-lg);
    text-align: start;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--color-text-subtle);
    opacity: 0.7;
  }

  .feature-card:hover {
    opacity: 0.85;
  }

  .feature-card[aria-current="true"] {
    color: var(--color-text);
    opacity: 1;
  }

  .feature-card__icon {
    inline-size: 20px;
    block-size: 20px;
    margin-block-end: var(--size-3);
    transition: opacity 0.2s;
  }

  .feature-card__icon .icon {
    inline-size: 100%;
    block-size: 100%;
  }

  .feature-card__header {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    margin-block-end: var(--size-2);
  }

  .feature-card__summary {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  /* Carousel Container */
  .carousel-container {
    position: relative;
  }

  .carousel-container .swiper {
    background: #f5f5f5;
    border-radius: var(--rounded-lg);
    padding: var(--size-8);
  }

  .carousel-container .swiper-slide {
    padding: 0 var(--size-4);
  }

  .carousel-container .swiper-slide img {
    border: 1px solid #e0e0e0;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  /* Navigation - Show only on hover */
  .carousel__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid var(--color-border);
    border-radius: var(--rounded-md);
    padding: var(--size-2) var(--size-3);
    cursor: pointer;
    font-size: var(--text-2xl);
    line-height: 1;
    transition: all 0.2s;
    z-index: 10;
    opacity: 0;
    pointer-events: none;
  }

  .carousel-container:hover .carousel__nav {
    opacity: 1;
    pointer-events: auto;
  }

  .carousel__nav:hover {
    background: white;
    box-shadow: var(--shadow-sm);
  }

  .carousel__nav--prev {
    left: var(--size-4);
  }

  .carousel__nav--next {
    right: var(--size-4);
  }

  /* Responsive visibility */
  @media (min-width: 768px) {
    .mobile-stack {
      display: none !important;
    }
  }

  @media (max-width: 767px) {
    .carousel-container {
      display: none !important;
    }
  }

  /* Mobile Stacked Layout */
  .mobile-stack {
    display: flex;
    flex-direction: column;
    gap: var(--size-8);
  }

  .mobile-feature {
    display: flex;
    flex-direction: column;
    gap: var(--size-6);
  }

  .mobile-feature__card {
    background: white;
    border-radius: var(--rounded-lg);
    padding: var(--size-6);
  }

  .mobile-feature__icon {
    inline-size: 20px;
    block-size: 20px;
    margin-block-end: var(--size-3);
  }

  .mobile-feature__icon .icon {
    inline-size: 100%;
    block-size: 100%;
  }

  .mobile-feature__header {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    margin-block-end: var(--size-2);
  }

  .mobile-feature__summary {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-subtle);
  }

  .mobile-feature__image-container {
    background: #f5f5f5;
    border-radius: var(--rounded-lg);
    padding: var(--size-6);
  }

  .mobile-feature__image-container img {
    inline-size: 100%;
    border: 1px solid #e0e0e0;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }
</style>
