<div style="max-width: 800px; margin: 0 auto; padding: var(--size-12);">
  <%= render Design::Navigation::Carousel::WidgetComponent.new do |widget| %>
    <% features.each do |feature| %>
      <% widget.with_slide do %>
        <div style="padding: var(--size-8);">
          <%= image_tag feature.preview.src, alt: feature.preview.caption, class: "w-full rounded-md" %>
        </div>
      <% end %>
    <% end %>

    <% widget.with_navigation do %>
      <button type="button"
              data-action="carousel#prev"
              class="carousel__nav carousel__nav--prev"
              aria-label="Previous slide">
        ‹
      </button>
      <button type="button"
              data-action="carousel#next"
              class="carousel__nav carousel__nav--next"
              aria-label="Next slide">
        ›
      </button>
    <% end %>

    <% features.each_with_index do |feature, index| %>
      <% widget.with_pagination do %>
        <%= render Design::Navigation::Carousel::PaginationComponent.new(index: index) %>
      <% end %>
    <% end %>
  <% end %>
</div>

<style>
  .carousel__content {
    touch-action: pan-y;
    user-select: none;
    -webkit-user-drag: none;
  }

  .carousel__content img {
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }

  .carousel__pagination {
    display: flex;
    justify-content: center;
    gap: var(--size-2);
    margin-block-start: var(--size-4);
  }

  .carousel__pagination-btn {
    padding: var(--size-1);
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .carousel__pagination-dot {
    display: block;
    inline-size: 10px;
    block-size: 10px;
    border-radius: var(--rounded-full);
    background-color: var(--color-border);
    transition: background-color 0.2s;
  }

  .carousel__pagination-btn.active .carousel__pagination-dot,
  .carousel__pagination-btn[aria-current="true"] .carousel__pagination-dot {
    background-color: var(--color-text);
  }

  /* Custom navigation buttons */
  .carousel__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid var(--color-border);
    border-radius: var(--rounded-md);
    padding: var(--size-2) var(--size-3);
    cursor: pointer;
    font-size: var(--text-2xl);
    line-height: 1;
    transition: all 0.2s;
    z-index: 10;
  }

  .carousel__nav:hover {
    background: white;
    box-shadow: var(--shadow-sm);
  }

  .carousel__nav--prev {
    left: var(--size-4);
  }

  .carousel__nav--next {
    right: var(--size-4);
  }
</style>
