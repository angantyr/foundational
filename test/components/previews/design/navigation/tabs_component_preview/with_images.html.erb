<div style="max-width: 1000px; margin: 0 auto; padding: var(--size-12);">
  <%= render Design::Navigation::Tabs::WidgetComponent.new(variant: :responsive) do |widget| %>
    <%# First loop: render all the buttons %>
    <% tabs.each do |tab| %>
      <% widget.with_button do %>
        <%= tab.header %>
      <% end %>
    <% end %>

    <%# Second loop: render all the panels with rich content %>
    <% tabs.each do |tab| %>
      <% widget.with_panel do %>
        <div class="feature-content">
          <%= image_tag tab.preview.src, alt: tab.preview.caption, class: "w-full rounded-md" %>
          <p class="text-sm text-subtle mt-2"><%= tab.preview.caption %></p>
          <p class="text-base mt-4 m-0"><%= tab.summary %></p>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
