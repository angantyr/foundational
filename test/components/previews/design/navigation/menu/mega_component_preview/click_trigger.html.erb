<%
  modules = [
    { label: "Corporate", icon: "hotel", description: "Manage companies, subsidiaries, offices, and people. Define reporting structures, organizational charts, departments, and teams." },
    { label: "Business", icon: "briefcase-business", description: "A set of defaults for managing solutions, products, and services. Onboard partners." },
    { label: "Catalog", icon: "book-open-text", description: "Build product pages on best practices for key features, benefits, detailed specs, related products and collateral." },
    { label: "Web", icon: "globe", description: "Managed multiple websites under multiple domains. Define information architecture, navigation, site, accessibility constraints." },
    { label: "Collateral", icon: "book-image", description: "types, protected, downloads, versioning." },
    { label: "Broadcast", icon: "radio-tower", description: "Anim auto id magna aliqua ad ad non deserunt sunt. Qui irure qui lorem cupidatat commodo sunt amet fugiat." },
    { label: "Store", icon: "shopping-cart", description: "Anim auto id magna aliqua ad ad non deserunt sunt. Qui irure qui lorem cupidatat commodo sunt amet fugiat." },
    { label: "Media", icon: "image", description: "Anim auto id magna aliqua ad ad non deserunt sunt. Qui irure qui lorem cupidatat commodo sunt amet fugiat." }
  ]
%>

<%= render Design::Navigation::Menu::MegaComponent.new(trigger: trigger) do |menu| %>
  <%= menu.with_brand do %>
    <%= render Design::Navigation::Elements::BrandComponent.new(
      logo: "brandmark.svg",
      href: "/",
      size: 64,
      animate_on_hover: true
    ) %>
  <% end %>

  <% ["Solutions", "Modules", "Features", "Platform", "Services"].each do |nav_label| %>
    <%= menu.with_nav_item do %>
      <%= render Design::Navigation::Menu::Mega::ItemComponent.new(
        label: nav_label,
        popover_id: "#{nav_label.downcase}-megapopover",
        trigger_actions: trigger == :hover ? "mouseenter->popover#debouncedShow mouseleave->popover#debouncedHide" : nil
      ) do |mega| %>
        <%= mega.with_header do %>
          <div class="megamenu__header">
            <h2 class="megamenu__header-title">Build your website one brick at a time</h2>
            <p class="megamenu__header-summary">Start small and add modules to address business needs as they emerge</p>
          </div>
        <% end %>

        <%= mega.with_links do %>
          <div class="megamenu__grid">
            <% modules.each do |mod| %>
              <%= render Design::Navigation::Elements::MenuItemComponent.new(
                label: mod[:label],
                href: "/modules/#{mod[:label].downcase}",
                icon: mod[:icon],
                description: mod[:description],
                variant: :card
              ) %>
            <% end %>
          </div>
        <% end %>

        <%= mega.with_footer do %>
          <div class="megamenu__footer">
            <a href="#" class="megamenu__footer-link">
              <span class="icon" aria-hidden="true">
                <%= image_tag "icons/sparkles.svg", size: 16, alt: "" %>
              </span>
              <span>Learn about your private AI</span>
            </a>

            <a href="#" class="megamenu__footer-link">
              <span class="icon" aria-hidden="true">
                <%= image_tag "icons/handshake.svg", size: 16, alt: "" %>
              </span>
              <span>Request a meeting</span>
            </a>

            <a href="#" class="megamenu__footer-link">
              <span class="icon" aria-hidden="true">
                <%= image_tag "icons/phone.svg", size: 16, alt: "" %>
              </span>
              <span>Contact sales</span>
            </a>

            <a href="/modules" class="megamenu__footer-link">
              <span class="icon" aria-hidden="true">
                <%= image_tag "icons/layout-dashboard.svg", size: 16, alt: "" %>
              </span>
              <span>View all modules</span>
              <span class="icon" aria-hidden="true">
                <%= image_tag "icons/arrow-long-right.svg", size: 16, alt: "" %>
              </span>
            </a>
          </div>
        <% end %>

        <%= mega.with_mobile_content do %>
          <div class="megamenu-mobile-scroll">
            <% modules.each do |mod| %>
              <a href="/modules/<%= mod[:label].downcase %>" class="megamenu-mobile-card">
                <span class="icon" aria-hidden="true">
                  <%= image_tag "icons/#{mod[:icon]}.svg", size: 24, alt: "" %>
                </span>
                <p class="megamenu-mobile-card__title"><%= mod[:label] %></p>
                <p class="megamenu-mobile-card__description"><%= mod[:description] %></p>
              </a>
            <% end %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= menu.with_desktop_action do %>
    <%= link_to "Sign In", "#", class: "btn btn--ghost btn--rounded show@md" %>
  <% end %>

  <%= menu.with_desktop_action do %>
    <%= link_to "Get Started", "#", class: "btn btn--primary btn--rounded" %>
  <% end %>

  <%= menu.with_mobile_action do %>
    <%= link_to "Contact Us", "#", class: "btn btn--outline" %>
  <% end %>

  <%= menu.with_mobile_action do %>
    <%= link_to "Sign In", "#", class: "btn btn--outline" %>
  <% end %>
<% end %>
