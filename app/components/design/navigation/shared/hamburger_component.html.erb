<% if checkbox_variant? %>
  <label for="<%= @target %>" class="mobile-menu-toggle hide@md flex items-center justify-center">
    <span class="hamburger-icon hamburger-icon--menu">
      <%= image_tag "icons/menu.svg", size: 48, alt: "" %>
    </span>
    <span class="hamburger-icon hamburger-icon--close">
      <%= image_tag "icons/x.svg", size: 48, alt: "" %>
    </span>
    <span class="sr-only"><%= @aria_label %></span>
  </label>
<% else %>
  <button type="button" popovertarget="<%= @target %>" class="hamburger-component btn btn--icon hide@md" aria-label="<%= @aria_label %>">
    <span class="hamburger-icon hamburger-icon--menu">
      <%= image_tag "icons/menu.svg", size: 48, alt: "" %>
    </span>
    <span class="hamburger-icon hamburger-icon--close">
      <%= image_tag "icons/x.svg", size: 48, alt: "" %>
    </span>
  </button>
<% end %>