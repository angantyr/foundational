<% if has_pattern? %>
  <!-- Pattern-based layout: multiple grids with different column counts -->
  <% batched_items.each_with_index do |batch, index| %>
    <div class="<%= grid_classes(batch[:columns]) %> <%= index > 0 ? "mbs-#{@gap}" : '' %>">
      <% batch[:items].each do |item| %>
        <%= item %>
      <% end %>
    </div>
  <% end %>
<% else %>
  <!-- Standard single grid -->
  <div class="<%= grid_classes %>">
    <% items.each do |item| %>
      <%= item %>
    <% end %>
  </div>
<% end %>
