<div class="header-menu">
  <div class="header-brand flex-item-no-shrink">
    <%= image_tag "brandmark.svg", size: 64, alt: "Foundational Logo" %>
    <%= link_to "/" do %>
    <% end %>
  </div>

  <nav class="show@md flex flex-1 justify-start pi-6">
    <div class="top_nav max-i-5xl flex flex-item-grow items-center justify-between font-semibold font-title tracking-wider">
      <div data-controller="popover" data-popover-placement-value="bottom-start" data-action="mouseenter->popover#debouncedShow mouseleave->popover#debouncedHide">
        <button type="button" class="btn" data-popover-target="trigger" popovertarget="solutions-popover" aria-haspopup="true">
          Solutions
          <span class="icon icon--chevron-down" aria-hidden="true">
            <%= image_tag "icons/chevron-down.svg", size: 16, alt: "" %>
          </span>
        </button>
        <div popover id="solutions-popover" class="popover popover--mega" data-popover-target="content" role="menu" aria-label="Solutions Menu">
          <%= render "home/modules_mega" %>
        </div>
      </div>

      <div data-controller="popover" data-popover-placement-value="bottom-start" data-action="mouseenter->popover#debouncedShow mouseleave->popover#debouncedHide">
        <button type="button" class="btn" data-popover-target="trigger" popovertarget="modules-popover" aria-haspopup="true">
          Modules
          <span class="icon icon--chevron-down" aria-hidden="true">
            <%= image_tag "icons/chevron-down.svg", size: 16, alt: "" %>
          </span>
        </button>
        <div popover id="modules-popover" class="popover popover--mega" data-popover-target="content" role="menu" aria-label="Modules Menu">
          <%= render "home/modules_mega" %>
        </div>
      </div>

      <div data-controller="popover" data-popover-placement-value="bottom-start" data-action="mouseenter->popover#debouncedShow mouseleave->popover#debouncedHide">
        <button type="button" class="btn" data-popover-target="trigger" popovertarget="features-popover" aria-haspopup="true">
          Features
          <span class="icon icon--chevron-down" aria-hidden="true">
            <%= image_tag "icons/chevron-down.svg", size: 16, alt: "" %>
          </span>
        </button>
        <div popover id="features-popover" class="popover popover--mega" data-popover-target="content" role="menu" aria-label="Features Menu">
          <%= render "home/modules_mega" %>
        </div>
      </div>

      <div data-controller="popover" data-popover-placement-value="bottom-start" data-action="mouseenter->popover#debouncedShow mouseleave->popover#debouncedHide">
        <button type="button" class="btn" data-popover-target="trigger" popovertarget="platform-popover" aria-haspopup="true">
          Platform
          <span class="icon icon--chevron-down" aria-hidden="true">
            <%= image_tag "icons/chevron-down.svg", size: 16, alt: "" %>
          </span>
        </button>
        <div popover id="platform-popover" class="popover popover--mega" data-popover-target="content" role="menu" aria-label="Platform Menu">
          <%= render "home/modules_mega" %>
        </div>
      </div>

      <div data-controller="popover" data-popover-placement-value="bottom-start" data-action="mouseenter->popover#debouncedShow mouseleave->popover#debouncedHide">
        <button type="button" class="btn" data-popover-target="trigger" popovertarget="services-popover" aria-haspopup="true">
          Services
          <span class="icon icon--chevron-down" aria-hidden="true">
            <%= image_tag "icons/chevron-down.svg", size: 16, alt: "" %>
          </span>
        </button>
        <div popover id="services-popover" class="popover popover--mega" data-popover-target="content" role="menu" aria-label="Services Menu">
          <%= render "home/modules_mega" %>
        </div>
      </div>
    </div>
  </nav>

  <div class="header-actions flex items-center gap flex-item-no-shrink">
    <%= link_to "Sign In", "#", class: "btn btn--ghost btn--rounded show@md" %>
    <%= link_to "Get Started", "#", class: "btn btn--primary btn--rounded" %>

    <div class="hide@md" data-controller="popover" data-popover-placement-value="bottom-end">
      <button type="button" class="btn btn--icon" data-popover-target="trigger" popovertarget="mobile-menu-mega-popover" aria-haspopup="true">
        <%= image_tag "icons/menu.svg", size: 48, alt: "Menu" %>
      </button>
      <div popover id="mobile-menu-mega-popover" class="popover popover--mobile-menu" data-popover-target="content" role="menu" aria-label="Mobile Menu">
        <div class="accordion">
          <details>
            <summary>Solutions</summary>
            <%= render "home/modules_mega_mobile" %>
          </details>
          <details>
            <summary>Modules</summary>
            <%= render "home/modules_mega_mobile" %>
          </details>
          <details>
            <summary>Features</summary>
            <%= render "home/modules_mega_mobile" %>
          </details>
          <details>
            <summary>Platform</summary>
            <%= render "home/modules_mega_mobile" %>
          </details>
          <details>
            <summary>Services</summary>
            <%= render "home/modules_mega_mobile" %>
          </details>
        </div>

        <div class="mobile-menu__footer">
          <%= link_to "Contact Us", "#", class: "btn btn--outline" %>
          <%= link_to "Sign In", "#", class: "btn btn--outline" %>
        </div>
      </div>
    </div>
  </div>
</div>